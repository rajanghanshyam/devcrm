// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------------------------------
// 1. Model: CompanyProfiles (mapped to company_profiles)
// ----------------------------------------------------------------------------
model CompanyProfiles {
  id                   String                 @id @default(uuid())
  name                 String
  email                String
  phone                String?
  address              String?
  gstin                String?
  pan                  String?
  state                String?
  bankName             String?                @map("bank_name")
  bankBranch           String?                @map("bank_branch")
  accountNo            String?                @map("account_no")
  ifsc                 String?
  headerImage          String?                @map("header_image")
  footerImage          String?                @map("footer_image")
  signatureImage       String?                @map("signature_image")
  template             String?                @default("minimal")
  quotationPrefix      String?                @default("QT-") @map("quotation_prefix")
  invoicePrefix        String?                @default("INV-") @map("invoice_prefix")
  challanPrefix        String?                @default("DC-") @map("challan_prefix")
  nextQuotationNumber  Int?                   @default(1) @map("next_quotation_number")
  nextInvoiceNumber    Int?                   @default(1) @map("next_invoice_number")
  nextChallanNumber    Int?                   @default(1) @map("next_challan_number")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  
  termsPresets         TermsPresets[]
  subscriptionPolicies SubscriptionPolicies[]
  quotations           Quotations[]
  invoices             Invoices[]
  deliveryChallans     DeliveryChallans[]

  @@map("company_profiles")
}

// ----------------------------------------------------------------------------
// 2. Model: Customers (mapped to customers)
// ----------------------------------------------------------------------------
model Customers {
  id               String             @id @default(uuid())
  name             String
  company          String?
  email            String?
  phone            String?
  gstin            String?
  state            String
  billingAddress   String?            @map("billing_address")
  shippingAddress  String?            @map("shipping_address")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  quotations       Quotations[]
  invoices         Invoices[]
  deliveryChallans DeliveryChallans[]
  leads            Leads[]
  subscriptions    Subscriptions[]
  reminders        Reminders[]

  @@map("customers")
}

// ----------------------------------------------------------------------------
// 3. Model: Products (mapped to products)
// ----------------------------------------------------------------------------
model Products {
  id                String          @id @default(uuid())
  name              String
  sku               String          @unique
  rate              Decimal         @default(0.00) @db.Decimal(15, 2)
  gstRate           Decimal         @default(18.00) @map("gst_rate") @db.Decimal(5, 2)
  hsnCode           String?         @map("hsn_code")
  description       String?
  itemType          String?         @default("Product") @map("item_type")
  mrp               Decimal?        @db.Decimal(15, 2)
  lastPurchasePrice Decimal?        @map("last_purchase_price") @db.Decimal(15, 2)
  sellPrice         Decimal?        @map("sell_price") @db.Decimal(15, 2)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  quotationItems    QuotationItems[]
  invoiceItems      InvoiceItems[]
  inventoryItem     InventoryItems?

  @@map("products")
}

// ----------------------------------------------------------------------------
// 4. Model: TermsPresets (mapped to terms_presets)
// ----------------------------------------------------------------------------
model TermsPresets {
  id               String           @id @default(uuid())
  companyProfileId String?          @map("company_profile_id")
  companyProfile   CompanyProfiles? @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  title            String
  content          String
  createdAt        DateTime         @default(now()) @map("created_at")

  quotations       Quotations[]
  invoices         Invoices[]

  @@map("terms_presets")
}

// ----------------------------------------------------------------------------
// 5. Model: SubscriptionPolicies (mapped to subscription_policies)
// ----------------------------------------------------------------------------
model SubscriptionPolicies {
  id                   String           @id @default(uuid())
  companyProfileId     String?          @map("company_profile_id")
  companyProfile       CompanyProfiles? @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  daysBeforeRenewal    Int              @default(7) @map("days_before_renewal")
  emailSubjectTemplate String?          @map("email_subject_template")
  emailBodyTemplate    String?          @map("email_body_template")
  isActive             Boolean?         @default(true) @map("is_active")
  createdAt            DateTime         @default(now()) @map("created_at")

  @@map("subscription_policies")
}

// ----------------------------------------------------------------------------
// 6. Model: Quotations (mapped to quotations)
// ----------------------------------------------------------------------------
model Quotations {
  id                String           @id @default(uuid())
  quotationNo       String           @unique @map("quotation_no")
  date              DateTime         @db.Date
  validUntil        DateTime?        @map("valid_until") @db.Date
  customerId        String           @map("customer_id")
  customer          Customers        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  subject           String?
  subtotal          Decimal          @default(0.00) @db.Decimal(15, 2)
  discountTotal     Decimal          @default(0.00) @map("discount_total") @db.Decimal(15, 2)
  cgstTotal         Decimal          @default(0.00) @map("cgst_total") @db.Decimal(15, 2)
  sgstTotal         Decimal          @default(0.00) @map("sgst_total") @db.Decimal(15, 2)
  igstTotal         Decimal          @default(0.00) @map("igst_total") @db.Decimal(15, 2)
  grandTotal        Decimal          @default(0.00) @map("grand_total") @db.Decimal(15, 2)
  status            String?          @default("Draft")
  terms             String?
  companyId         String?          @map("company_id")
  company           CompanyProfiles? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  termsPresetId     String?          @map("terms_preset_id")
  termsPreset       TermsPresets?    @relation(fields: [termsPresetId], references: [id], onDelete: SetNull)
  freight           Decimal?         @default(0.00) @db.Decimal(15, 2)
  additionalDiscount Decimal?        @default(0.00) @map("additional_discount") @db.Decimal(15, 2)
  customerSignature String?          @map("customer_signature")
  customerSignedAt  DateTime?        @map("customer_signed_at")
  revisionOfId      String?          @map("revision_of_id")
  revisionOf        Quotations?      @relation("RevisionHistory", fields: [revisionOfId], references: [id], onDelete: SetNull)
  originalQuoteId   String?          @map("original_quote_id")
  originalQuote     Quotations?      @relation("OriginalQuoteHistory", fields: [originalQuoteId], references: [id], onDelete: SetNull)
  revisionNumber    Int?             @default(0) @map("revision_number")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  quotationItems     QuotationItems[]
  invoices           Invoices[]
  revisions          Quotations[]     @relation("RevisionHistory")
  originatedRevisions Quotations[]    @relation("OriginalQuoteHistory")

  @@map("quotations")
}

// ----------------------------------------------------------------------------
// 7. Model: QuotationItems (mapped to quotation_items)
// ----------------------------------------------------------------------------
model QuotationItems {
  id              Int        @id @default(autoincrement())
  quotationId     String     @map("quotation_id")
  quotation       Quotations @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId       String?    @map("product_id")
  product         Products?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName     String     @map("product_name")
  description     String?
  hsnCode         String?    @map("hsn_code")
  quantity        Decimal    @default(1) @db.Decimal(15, 4)
  rate            Decimal    @default(0.00) @db.Decimal(15, 2)
  discountPercent Decimal?   @default(0.00) @map("discount_percent") @db.Decimal(5, 2)
  gstPercent      Decimal?   @default(18.00) @map("gst_percent") @db.Decimal(5, 2)

  @@map("quotation_items")
}

// ----------------------------------------------------------------------------
// 8. Model: Invoices (mapped to invoices)
// ----------------------------------------------------------------------------
model Invoices {
  id                String           @id @default(uuid())
  invoiceNo         String           @unique @map("invoice_no")
  quotationNo       String?          @map("quotation_no")
  quotation         Quotations?      @relation(fields: [quotationNo], references: [quotationNo], onDelete: SetNull)
  date              DateTime         @db.Date
  dueDate           DateTime?        @map("due_date") @db.Date
  customerId        String           @map("customer_id")
  customer          Customers        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  subject           String?
  subtotal          Decimal          @default(0.00) @db.Decimal(15, 2)
  discountTotal     Decimal          @default(0.00) @map("discount_total") @db.Decimal(15, 2)
  cgstTotal         Decimal          @default(0.00) @map("cgst_total") @db.Decimal(15, 2)
  sgstTotal         Decimal          @default(0.00) @map("sgst_total") @db.Decimal(15, 2)
  igstTotal         Decimal          @default(0.00) @map("igst_total") @db.Decimal(15, 2)
  grandTotal        Decimal          @default(0.00) @map("grand_total") @db.Decimal(15, 2)
  status            String?          @default("Unpaid")
  terms             String?
  companyId         String?          @map("company_id")
  company           CompanyProfiles? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  termsPresetId     String?          @map("terms_preset_id")
  termsPreset       TermsPresets?    @relation(fields: [termsPresetId], references: [id], onDelete: SetNull)
  freight           Decimal?         @default(0.00) @db.Decimal(15, 2)
  additionalDiscount Decimal?        @default(0.00) @map("additional_discount") @db.Decimal(15, 2)
  customerSignature String?          @map("customer_signature")
  customerSignedAt  DateTime?        @map("customer_signed_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  invoiceItems      InvoiceItems[]

  @@map("invoices")
}

// ----------------------------------------------------------------------------
// 9. Model: InvoiceItems (mapped to invoice_items)
// ----------------------------------------------------------------------------
model InvoiceItems {
  id              Int       @id @default(autoincrement())
  invoiceId       String    @map("invoice_id")
  invoice         Invoices  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId       String?   @map("product_id")
  product         Products? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName     String    @map("product_name")
  description     String?
  hsnCode         String?   @map("hsn_code")
  quantity        Decimal   @default(1) @db.Decimal(15, 4)
  rate            Decimal   @default(0.00) @db.Decimal(15, 2)
  discountPercent Decimal?  @default(0.00) @map("discount_percent") @db.Decimal(5, 2)
  gstPercent      Decimal?  @default(18.00) @map("gst_percent") @db.Decimal(5, 2)

  @@map("invoice_items")
}

// ----------------------------------------------------------------------------
// 10. Model: DeliveryChallans (mapped to delivery_challans)
// ----------------------------------------------------------------------------
model DeliveryChallans {
  id               String           @id @default(uuid())
  challanNo        String           @unique @map("challan_no")
  date             DateTime         @db.Date
  customerId       String           @map("customer_id")
  customer         Customers        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleNo        String?          @map("vehicle_no")
  transporter      String?
  lrNumber         String?          @map("lr_number")
  dispatchAddress  String?          @map("dispatch_address")
  status           String?          @default("Dispatched")
  notes            String?
  companyId        String?          @map("company_id")
  company          CompanyProfiles? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  deliveryChallanItems DeliveryChallanItems[]

  @@map("delivery_challans")
}

// ----------------------------------------------------------------------------
// 11. Model: DeliveryChallanItems (mapped to delivery_challan_items)
// ----------------------------------------------------------------------------
model DeliveryChallanItems {
  id                Int              @id @default(autoincrement())
  deliveryChallanId String           @map("delivery_challan_id")
  deliveryChallan   DeliveryChallans @relation(fields: [deliveryChallanId], references: [id], onDelete: Cascade)
  productName       String           @map("product_name")
  quantity          Decimal          @default(1) @db.Decimal(15, 4)
  hsnCode           String?          @map("hsn_code")
  description       String?

  @@map("delivery_challan_items")
}

// ----------------------------------------------------------------------------
// 12. Model: Leads (mapped to leads)
// ----------------------------------------------------------------------------
model Leads {
  id               String     @id @default(uuid())
  customerId       String?    @map("customer_id")
  customer         Customers? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name             String
  company          String?
  email            String?
  phone            String?
  value            Decimal    @default(0.00) @db.Decimal(15, 2)
  status           String?    @default("New")
  source           String?
  notes            String?
  date             DateTime?  @db.Date
  conversionStatus String?    @default("Cold") @map("conversion_status")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@map("leads")
}

// ----------------------------------------------------------------------------
// 13. Model: Subscriptions (mapped to subscriptions)
// ----------------------------------------------------------------------------
model Subscriptions {
  id              String      @id @default(uuid())
  customerId      String      @map("customer_id")
  customer        Customers   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceName     String      @map("service_name")
  amount          Decimal     @default(0.00) @db.Decimal(15, 2)
  billingCycle    String      @map("billing_cycle")
  startDate       DateTime    @db.Date @map("start_date")
  nextRenewalDate DateTime    @db.Date @map("next_renewal_date")
  status          String?     @default("Active")
  description     String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  reminders       Reminders[]

  @@map("subscriptions")
}

// ----------------------------------------------------------------------------
// 14. Model: Reminders (mapped to reminders)
// ----------------------------------------------------------------------------
model Reminders {
  id             String         @id @default(uuid())
  title          String
  description    String?
  dueDate        DateTime       @map("due_date")
  status         String?        @default("Pending")
  priority       String?        @default("Medium")
  relatedTo      String?        @map("related_to")
  subscriptionId String?        @map("subscription_id")
  subscription   Subscriptions? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  customerId     String?        @map("customer_id")
  customer       Customers?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("reminders")
}

// ----------------------------------------------------------------------------
// 15. Model: InventoryItems (mapped to inventory_items)
// ----------------------------------------------------------------------------
model InventoryItems {
  id                  String          @id @default(uuid())
  sku                 String          @unique
  product             Products        @relation(fields: [sku], references: [sku], onDelete: Restrict)
  productName         String          @map("product_name")
  category            String?
  quantity            Decimal         @default(0.0000) @db.Decimal(15, 4)
  minQuantity         Decimal         @default(0.0000) @map("min_quantity") @db.Decimal(15, 4)
  purchaseFrom        String?         @map("purchase_from")
  unitPrice           Decimal         @default(0.00) @map("unit_price") @db.Decimal(15, 2)
  latestPurchasePrice Decimal?        @map("latest_purchase_price") @db.Decimal(15, 2)
  lastUpdated         DateTime        @default(now()) @map("last_updated")
  createdAt           DateTime        @default(now()) @map("created_at")

  inventoryLogs       InventoryLogs[]

  @@map("inventory_items")
}

// ----------------------------------------------------------------------------
// 16. Model: InventoryLogs (mapped to inventory_logs)
// ----------------------------------------------------------------------------
model InventoryLogs {
  id              String         @id @default(uuid())
  inventoryItemId String         @map("inventory_item_id")
  inventoryItem   InventoryItems @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  date            DateTime       @default(now())
  type            String
  quantity        Decimal        @db.Decimal(15, 4)
  reason          String?
  prevQty         Decimal        @map("prev_qty") @db.Decimal(15, 4)
  newQty          Decimal        @map("new_qty") @db.Decimal(15, 4)
  supplierName    String?        @map("supplier_name")
  customerName    String?        @map("customer_name")

  @@map("inventory_logs")
}

// ----------------------------------------------------------------------------
// 17. Model: UserProfiles (mapped to user_profiles)
// ----------------------------------------------------------------------------
model UserProfiles {
  id        String   @id
  name      String?
  email     String?  @unique
  role      String?
  password  String?
  isActive  Boolean? @default(true) @map("is_active")
  rights    String?  @db.Text
  createdAt String?  @map("created_at")

  @@map("user_profiles")
}

// ----------------------------------------------------------------------------
// 18. Model: AppData (mapped to app_data)
// ----------------------------------------------------------------------------
model AppData {
  key       String  @id
  dataJson  String? @map("data_json") @db.Text
  updatedAt String? @map("updated_at")

  @@map("app_data")
}
